generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
  previewFeatures = ["multiSchema"]
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "chat"]
}

// shared enum — used across Fetched Data, Outreach, Pipeline, and Reference sections
enum SourceSystem {
  SAM
  USASPENDING
  MANUAL

  @@schema("public")
}

// ─── USERS ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  READ_ONLY
  USER

  @@schema("public")
}

model User {
  id            String   @id @default(cuid())
  clerkId       String   @unique
  email         String   @unique
  name          String?
  role          UserRole @default(USER)
  isActive      Boolean  @default(true)
  imageUrl      String?
  digestEnabled Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  favorites           Favorite[]
  chatConversations   ChatConversation[]
  contactInteractions ContactInteraction[]
  inboxItemNotes      InboxItemNote[]

  @@schema("public")
}

model Favorite {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  awardId       String?
  award         Award?       @relation(fields: [awardId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())

  @@unique([userId, opportunityId])
  @@unique([userId, awardId])
  @@index([userId])
  @@schema("public")
}

model ChatConversation {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  isPrivate Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime
  messages  ChatMessage[]

  @@index([userId])
  @@index([expiresAt])
  @@index([isPrivate, createdAt])
  @@schema("chat")
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  toolCalls      Json?
  createdAt      DateTime         @default(now())

  @@index([conversationId, createdAt])
  @@schema("chat")
}

// ─── FETCHED DATA ─────────────────────────────────────────────────────────────

enum Type {
  PRE_SOLICITATION
  AWARD_NOTICE
  SOURCES_SOUGHT
  SPECIAL_NOTICE
  SOLICITATION
  OTHER

  @@schema("public")
}

enum OppTag {
  INDUSTRY_DAY
  GENERAL

  @@schema("public")
}

enum IndustryDayStatus {
  OPEN
  NOT_ATTENDING
  ATTENDING
  ATTENDED
  PAST_EVENT

  @@schema("public")
}

model Opportunity {
  id     String       @id @default(cuid())
  source SourceSystem @default(SAM)

  // Dedup for SAM — upsert key is solicitationNumber when present, noticeId as fallback
  noticeId           String? @unique
  solicitationNumber String? @unique
  title              String?
  type               Type?
  tag                OppTag  @default(GENERAL)
  active             Boolean @default(true)

  description   String?
  resourceLinks String[] @default([]) // SAM.gov attachment download URLs

  postedDate       DateTime?
  responseDeadline DateTime?

  // Classification
  naicsCodes String[] @default([])
  pscCode    String?
  setAside   String? // store raw like "NONE", "SBA", etc.

  // Org / office metadata
  fullParentPathName String?

  city        String?
  state       String?
  zip         String?
  countryCode String?

  // Relationships
  buyingOrganizationId String?
  buyingOrganization   BuyingOrganization? @relation(fields: [buyingOrganizationId], references: [id], onDelete: SetNull)

  // Inbox workflow
  inboxItems   InboxItem[]
  scoringQueue ScoringQueue?

  // Contacts scraped from SAM for this opportunity (optional but useful)
  contactLinks ContactLink[]

  favorites   Favorite[]
  attachments OpportunityAttachment[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  industryDay IndustryDay?
  awards      Award[]

  @@index([postedDate])
  @@index([responseDeadline])
  @@index([naicsCodes], type: Gin)
  @@index([pscCode])
  @@index([type])
  @@index([title])
  @@schema("public")
}

model OpportunityAttachment {
  id              String    @id @default(cuid())
  resourceId      String    @unique
  name            String // original filename
  mimeType        String? // ".pdf", ".docx", etc.
  size            Int? // bytes
  postedDate      DateTime?
  attachmentOrder Int?
  downloadUrl     String // full SAM.gov download URL

  // Step Two fields (on-demand PDF parsing)
  parsedText String?
  parsedAt   DateTime?

  // Step Three fields (automated opportunity scoring)
  scoreResult Json?
  scoredAt    DateTime?

  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([opportunityId])
  @@index([name])
  @@index([parsedAt])
  @@index([scoredAt])
  @@index([createdAt])
  @@schema("public")
}

model Award {
  id     String       @id @default(cuid())
  source SourceSystem @default(USASPENDING)

  externalId String? @unique

  description String?

  naicsCodes String[] @default([])
  pscCode    String?

  obligatedAmount Decimal?  @db.Decimal(18, 2)
  startDate       DateTime?
  endDate         DateTime?

  // TODO: Ensure that award is inherantly linked
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  buyingOrganizationId String?
  buyingOrganization   BuyingOrganization? @relation(fields: [buyingOrganizationId], references: [id], onDelete: SetNull)

  recipientId String?
  recipient   Recipient? @relation(fields: [recipientId], references: [id], onDelete: SetNull)

  inboxItems InboxItem[]

  favorites Favorite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startDate])
  @@index([endDate])
  @@index([naicsCodes], type: Gin)
  @@index([pscCode])
  @@index([buyingOrganizationId])
  @@index([recipientId])
  @@schema("public")
}

model IndustryDay {
  id     String       @id @default(cuid())
  source SourceSystem @default(SAM)

  // Deduplication check
  externalId String? @unique
  title      String
  summary    String?

  location  String?
  eventDate DateTime?

  host String?

  status IndustryDayStatus @default(OPEN)

  buyingOrganizationId String?
  buyingOrganization   BuyingOrganization? @relation(fields: [buyingOrganizationId], references: [id], onDelete: SetNull)

  opportunityId String?      @unique
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contactLinks ContactLink[]

  @@index([eventDate])
  @@index([status])
  @@schema("public")
}

// ─── REFERENCE ────────────────────────────────────────────────────────────────

enum OrgLevel {
  AGENCY
  SUBAGENCY
  OFFICE
  OTHER

  @@schema("public")
}

model BuyingOrganization {
  id      String  @id @default(cuid())
  name    String  @unique
  website String?

  level    OrgLevel             @default(OTHER)
  parentId String?
  parent   BuyingOrganization?  @relation("BuyingOrgTree", fields: [parentId], references: [id], onDelete: SetNull)
  children BuyingOrganization[] @relation("BuyingOrgTree")

  externalId String? // Office/org identifier or code
  pathName   String? // cached full path for fast display

  contactLinks  ContactLink[]
  inboxItems    InboxItem[]
  awards        Award[]
  industryDay   IndustryDay[]
  opportunities Opportunity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([parentId])
  @@index([level])
  @@index([name, externalId])
  @@schema("public")
}

model Recipient {
  id      String  @id @default(cuid())
  name    String
  website String?
  uei     String? @unique

  awards Award[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([uei])
  @@schema("public")
}

model PscClass {
  psc              String  @id // 4-digit PSC code (e.g., "8925")
  title            String // e.g., "SUGAR, CONFECTIONERY, AND NUTS"
  inclusions       String?
  exclusions       String?
  notes            String?
  isSupplyTigerPsc Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stockNumbers         FederalLogisticsInformationSystem[]
  commercialItemDescs  CommercialItemDesc[]

  @@index([isSupplyTigerPsc])
  @@schema("public")
}

model FederalLogisticsInformationSystem {
  id              String   @id @default(cuid())
  nsn             String   @unique // pscCode + niin (13 chars)
  niin            String // 9-digit NIIN
  pscCode         String
  pscClass        PscClass @relation(fields: [pscCode], references: [psc], onDelete: Cascade)
  itemName        String
  characteristics String?
  commonName      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pscCode])
  @@index([itemName])
  @@index([commonName])
  @@schema("public")
}

model CommercialItemDesc {
  id          String   @id @default(cuid())
  cid         String   @unique // e.g., "A-A-20177G"
  date        String? // Date string(s) — variable format from source
  description String
  qaPkg       String?
  qaPkgDate   String?
  pscCode     String
  pscClass    PscClass @relation(fields: [pscCode], references: [psc], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pscCode])
  @@schema("public")
}

// ─── OUTREACH ─────────────────────────────────────────────────────────────────

enum ContactType {
  PRIMARY
  SECONDARY
  OTHER

  @@schema("public")
}

enum OutreachStatus {
  SENT
  RESPONDED
  NO_REPLY
  FOLLOW_UP
  MEETING_SCHEDULED
  CLOSED

  @@schema("public")
}

model Contact {
  id String @id @default(cuid())

  fullName String?
  email    String? @unique
  phone    String?
  title    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  links        ContactLink[]
  interactions ContactInteraction[]

  @@index([email])
  @@index([phone])
  @@schema("public")
}

model ContactLink {
  id String @id @default(cuid())

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  type   ContactType  @default(OTHER)
  source SourceSystem @default(SAM)

  // Dedupe key from source payload (scoped to the parent record)
  externalId String

  // Parent pointers (only ONE should be set per row)
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  industryDayId String?
  industryDay   IndustryDay? @relation(fields: [industryDayId], references: [id], onDelete: Cascade)

  inboxItemId String?
  inboxItem   InboxItem? @relation(fields: [inboxItemId], references: [id], onDelete: Cascade)

  buyingOrganizationId String?
  buyingOrganization   BuyingOrganization? @relation(fields: [buyingOrganizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Scoped uniqueness so the same externalId can exist under different parents
  @@unique([opportunityId, externalId])
  @@unique([industryDayId, externalId])
  @@unique([inboxItemId, externalId])
  @@unique([buyingOrganizationId, externalId])
  @@index([opportunityId])
  @@index([industryDayId])
  @@index([inboxItemId])
  @@index([buyingOrganizationId])
  @@schema("public")
}

model ContactInteraction {
  id String @id @default(cuid())

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  status OutreachStatus
  note   String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  loggedAt DateTime @default(now())

  @@index([contactId, loggedAt])
  @@schema("public")
}

// ─── PIPELINE ─────────────────────────────────────────────────────────────────

enum AcquisitionPath {
  MICROPURCHASE
  GSA
  OPEN_MARKET
  SUBCONTRACTING

  @@schema("public")
}

enum InboxStatus {
  NEW
  IN_REVIEW
  QUALIFIED
  DISMISSED
  CONTACTED
  CLOSED

  @@schema("public")
}

model InboxItem {
  id String @id @default(cuid())

  source          SourceSystem
  acquisitionPath AcquisitionPath
  type            Type
  tag             OppTag

  title    String?
  summary  String?
  deadline DateTime?

  reviewStatus InboxStatus @default(NEW)
  reviewedBy   String?
  reviewedAt   DateTime?

  attachmentScore Int?
  matchedSignals  Json?

  buyingOrganizationId String?
  buyingOrganization   BuyingOrganization? @relation(fields: [buyingOrganizationId], references: [id], onDelete: SetNull)

  awardId String?
  award   Award?  @relation(fields: [awardId], references: [id], onDelete: SetNull)

  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  contactLinks ContactLink[]
  notes        InboxItemNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([source, opportunityId])
  @@unique([source, awardId])
  @@index([reviewStatus])
  @@index([acquisitionPath])
  @@index([type])
  @@index([tag])
  @@index([createdAt])
  @@index([deadline])
  @@index([buyingOrganizationId])
  @@index([awardId])
  @@index([opportunityId])
  @@schema("public")
}

model InboxItemNote {
  id String @id @default(cuid())

  inboxItemId String
  inboxItem   InboxItem @relation(fields: [inboxItemId], references: [id], onDelete: Cascade)

  text   String
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@index([inboxItemId, createdAt])
  @@schema("public")
}

// ─── SYSTEM ───────────────────────────────────────────────────────────────────

enum SyncStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED

  @@schema("public")
}

enum ScoringQueueStatus {
  PENDING
  APPROVED
  DISMISSED

  @@schema("public")
}

model ScoringQueue {
  id             String             @id @default(cuid())
  opportunityId  String             @unique
  opportunity    Opportunity        @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  score          Int
  matchedSignals Json              // Array of { type, value, source } objects
  status         ScoringQueueStatus @default(PENDING)
  reviewedBy     String?
  reviewedAt     DateTime?
  expiresAt      DateTime           // set to min(createdAt+14d, opportunity.responseDeadline)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([status])
  @@index([expiresAt])
  @@schema("public")
}

model SyncLog {
  id              String     @id @default(cuid())
  jobId           String
  jobName         String
  startedAt       DateTime   @default(now())
  completedAt     DateTime?
  status          SyncStatus @default(RUNNING)
  recordsAffected Int?
  errorMessage    String?

  @@index([jobId])
  @@index([startedAt])
  @@schema("public")
}

model AppConfig {
  key       String   @id
  values    String[]
  updatedAt DateTime @updatedAt

  @@schema("public")
}
