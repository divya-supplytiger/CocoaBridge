generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AcquisitionPath {
  MICROPURCHASE
  GSA
  OPEN_MARKET
  SUBCONTRACTING
}

enum InboxStatus {
  NEW
  IN_REVIEW
  QUALIFIED
  DISMISSED
  CONTACTED
  CLOSED
}

enum Type {
  PRE_SOLICITATION
  AWARD_NOTICE
  SOURCES_SOUGHT
  SPECIAL_NOTICE
  SOLICITATION
  OTHER
}

enum OppTag {
  INDUSTRY_DAY
  GENERAL
}

enum ContactType {
  PRIMARY
  SECONDARY
  OTHER
}

enum IndustryDayStatus {
  OPEN
  NOT_ATTENDING
  ATTENDING
  ATTENDED
  PAST_EVENT
}

enum SourceSystem {
  SAM
  USASPENDING
  MANUAL
}

model Contact {
  id   String      @id @default(cuid())
  type ContactType @default(OTHER)

  fullName String?
  email    String?
  phone    String?
  title    String?

  // Durable relationship
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  // Workflow relationship
  inboxItemId String?
  inboxItem   InboxItem? @relation(fields: [inboxItemId], references: [id], onDelete: SetNull)

  // Opportunity
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  // IndustryDay
  industryDayId String?
  industryDay   IndustryDay? @relation(fields: [industryDayId], references: [id], onDelete: SetNull)

  externalId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Indexes
  @@index([email])
  @@index([phone])
  @@index([organizationId])
  @@index([opportunityId])
  @@index([industryDayId])
  @@index([inboxItemId])
}

model Organization {
  id       String  @id @default(cuid())
  name     String
  uei      String? @unique
  cageCode String?
  website  String?

  contacts Contact[]

  inboxItems    InboxItem[]
  awards        Award[]
  industryDay   IndustryDay[]
  opportunities Opportunity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([cageCode])
}

model Award {
  id     String       @id @default(cuid())
  source SourceSystem @default(USASPENDING)

  externalAwardId String? @unique
  awardingAgency  String?
  awardingOffice  String?

  naicsCodes String[] @default([])
  pscCode    String?

  obligatedAmount Decimal?  @db.Decimal(18, 2)
  startDate       DateTime?
  endDate         DateTime?

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  inboxItems InboxItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startDate])
  @@index([endDate])
  @@index([naicsCodes], type: Gin)
  @@index([pscCode])
}

model IndustryDay {
  id     String       @id @default(cuid())
  source SourceSystem @default(SAM)

  // Deduplication check
  externalEventId String? @unique
  title           String
  summary         String?

  location  String?
  eventDate DateTime?

  host String?

  status IndustryDayStatus @default(OPEN)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  opportunityId String?      @unique
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts Contact[]

  inboxItems InboxItem[]

  @@index([eventDate])
  @@index([status])
}

model Opportunity {
  id     String       @id @default(cuid())
  source SourceSystem @default(SAM)

  // Dedup for SAM
  noticeId           String? @unique
  solicitationNumber String?
  title              String?
  type               Type?
  tag                OppTag  @default(GENERAL)
  active             Boolean @default(true)

  description String?

  postedDate       DateTime?
  responseDeadline DateTime?

  // Classification
  naicsCodes String[] @default([])
  pscCode    String?
  setAside   String? // store raw like "NONE", "SBA", etc.

  // Org / office metadata
  fullParentPathName String?
  city               String?
  state              String?
  zip                String?
  countryCode        String?

  // Relationships
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  // Inbox workflow
  inboxItems InboxItem[]

  // Contacts scraped from SAM for this opportunity (optional but useful)
  contacts Contact[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  industryDay IndustryDay?

  @@index([postedDate])
  @@index([responseDeadline])
  @@index([naicsCodes], type: Gin)
  @@index([pscCode])
  @@index([type])
  @@index([solicitationNumber])
  @@index([title])
}

model InboxItem {
  id String @id @default(cuid())

  source          SourceSystem
  acquisitionPath AcquisitionPath
  type            Type
  tag             OppTag

  title   String?
  summary String?
  notes   String?

  reviewStatus InboxStatus @default(NEW)
  reviewedBy   String?
  reviewedAt   DateTime?

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  awardId String?
  award   Award?  @relation(fields: [awardId], references: [id], onDelete: SetNull)

  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  industryDayId String?
  industryDay   IndustryDay? @relation(fields: [industryDayId], references: [id], onDelete: SetNull)

  contacts Contact[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reviewStatus])
  @@index([acquisitionPath])
  @@index([type])
  @@index([tag])
  @@index([createdAt])
  @@index([organizationId])
  @@index([awardId])
  @@index([opportunityId])
  @@index([industryDayId])
}
