{
  "name": "cocoabridge-mcp",
  "version": "1.0.0",
  "type": "module",
  "description": "MCP server for SupplyTiger procurement intelligence",
  "prisma": {
    "schema": "../backend/prisma/schema.prisma"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "dotenv": "^16.6.1",
    "pg": "^8.17.2",
    "prisma": "^7.3.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "^0.21.1"
  },
  "scripts": {
    "start": "node src/server.js",
    "stdio": "node src/stdio.js",
    "inspect:http": "npx @modelcontextprotocol/inspector node src/server.js",
    "inspect:stdio": "set DANGEROUSLY_OMIT_AUTH=true && npx @modelcontextprotocol/inspector node src/stdio.js",
    "postinstall": "node scripts/prisma-generate.mjs"
  },
